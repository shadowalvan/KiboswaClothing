# VULN: SSTI in calculator
@app.route("/calculate")
@login_required
def calculate():
    expression = request.args.get('expr', '2+2')
    
    # VULN: SSTI and Code Injection via eval
    template = f"""
    <div class="calculator">
        <h2>Calculator (SSTI Demo)</h2>
        <form method="GET">
            <input type="text" name="expr" value="{expression}" size="50">
            <button type="submit">Calculate</button>
        </form>
        <h3>Result:</h3>
        <div style="background:#f0f0f0; padding:20px;">
            Expression: {expression}<br>
            Result: 
    """
    
    try:
        # VULN: eval on user input
        result = eval(expression)
        template += f"<b>{result}</b>"
    except Exception as e:
        template += f"<b style='color:red'>Error: {e}</b>"
    
    template += """
        </div>
        <p>Tip: Try {{7*7}} or __import__('os').system('whoami')</p>
        <a href="/dashboard">Back</a>
    </div>
    """
    return render_template_string(template)

