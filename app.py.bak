# Stored XSS
@app.route("/guestbook", methods=['GET', 'POST'])
@login_required
def guestbook():
    if request.method == 'POST':
        message = request.form.get('message', '')
        # VULN: Stored XSS - no sanitization
        xss_messages.append({
            'username': current_user.username,
            'message': message
        })
        return redirect(url_for('guestbook'))
    
    # Display messages
    messages_html = ""
    for msg in xss_messages:
        # VULN: Stored XSS - messages not escaped
        messages_html += f"""
        <div style="border:1px solid #ccc; margin:10px; padding:10px;">
            <strong>{msg['username']}</strong><br>
            {msg['message']}
        </div>
        """
    
    return render_template_string("""
        <h2>Guestbook (Stored XSS)</h2>
        <form method="POST">
            <textarea name="message" rows="3" cols="50" placeholder="Leave a message..."></textarea><br>
            <button type="submit">Post Message</button>
        </form>
        <h3>Messages:</h3>
        """ + messages_html + """
        <a href="/dashboard">Back to Dashboard</a>
        <p>Tip: Try <script>alert('XSS')</script></p>
    """)

