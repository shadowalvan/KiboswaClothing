from flask_login import LoginManager, UserMixin, login_user, logout_user, login_required, current_user

app = Flask(__name__)
app.secret_key = "$C%2#3fvms$qu$@z"  # intentionally weak for CTF

# Initialize Flask-Login
login_manager = LoginManager()
login_manager.init_app(app)
login_manager.login_view = "login"

# -------------------------------
# User class
# -------------------------------
class User(UserMixin):
    def __init__(self, id, username, role="user"):
        self.id = id
        self.username = username
        self.role = role

# -------------------------------
# Fake database
# -------------------------------
users = {
    "1": {"username": "alvan", "password": "1234", "role": "user"},
    "2": {"username": "admin", "password": "admin123", "role": "admin"}
}

products = {
    "0": {"name": "Admin Secret Product", "price": "FTA{hidd3n_pr0duct}", "owner": "admin"},
    "1": {"name": "Men stripped button Front Shirt", "price": "$21.99"},
    "2": {"name": "Cable Knit Shirt", "price": "$21.99"},
    "3": {"name": "Short Sleeve Collar Shirt", "price": "$23.99"},
    "4": {"name": "Round Neck Knitted Shirt", "price": "$24.99"},
    "5": {"name": "Men's Vintage Floral Retro", "price": "$27.99"},
}

orders = {
    "1": "Order: Kiboswa Hoodie",
    "2": "Order: Kiboswa T-Shirt"
}

# -------------------------------
# User loader for Flask-Login
# -------------------------------
@login_manager.user_loader
def load_user(user_id):
    user_info = users.get(user_id)
    if user_info:
        return User(id=user_id, username=user_info["username"], role=user_info.get("role", "user"))
    return None

# -------------------------------
# Routes
# -------------------------------

@app.route("/")
@login_required
def dashboard():
    return render_template("dashboard.html", user=current_user, role=current_user.role)

@app.route("/login", methods=["GET", "POST"])
def login():
    error = None
    if request.method == "POST":
        username = request.form.get("username")
        password = request.form.get("password")

        for user_id, user in users.items():
            if user["username"] == username and user["password"] == password:
                user_obj = User(user_id, username, user.get("role", "user"))
                login_user(user_obj)
                return redirect(url_for("dashboard"))
        error = "Invalid Credentials"

    return render_template("login.html", error=error)

@app.route("/logout")
@login_required
def logout():
    logout_user()
    return redirect(url_for("login"))

@app.route("/products")
@login_required
def products_page():
    return render_template("products.html", products=products, user=current_user)

@app.route("/product")
@login_required
def product_detail():
    product_id = request.args.get("id")
    product = products.get(product_id)
    if not product:
        return "Product not found"

    # Only Admin can see product 0
    if product_id == "0" and current_user.role != "admin":
        return "Access Denied"

    return f"""
        #<h1>{product['name']}</h1>
        #<p>Price: {product['price']}</p>
        #<p>Product ID: {product_id}</p>
    
"""
@app.route("/orders")
@login_required
def view_orders():
    # IDOR vulnerability intentionally left
    user_id = request.args.get("user_id", current_user.id)
    return orders.get(user_id, "No order found")

@app.route("/cart")
@login_required
def cart_page():
    return render_template("cart.html", user=current_user)

@app.route("/profile")
@login_required
def profile():
    return render_template("profile.html", user=current_user)

@app.route("/admin")
@login_required
def admin_panel():
    if current_user.role != "admin":
        return "Access Denied"
    return render_template("admin.html", user=current_user)

@app.route("/about")
@login_required
def about_page():
    return render_template("about.html", user=current_user)

@app.route("/contact")
@login_required
def contact_page():
    return render_template("contact.html", user=current_user)

# -------------------------------
# Run App
# -------------------------------
if __name__ == "__main__":
    app.run(debug=True)

